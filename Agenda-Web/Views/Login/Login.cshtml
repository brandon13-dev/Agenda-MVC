
@{
    ViewBag.Title = "Login";
}

<div class="container d-flex justify-content-center px-4">
    <div class="card p-4 text-center login-card">

        <div class="card-title mb-0">
            <i class="bi bi-person-bounding-box icon-rh"></i>
            <h4 class="mt-3 fw-bold text-dark">Agenda de RH</h4>
        </div>
        <div class="card-subtitle text-muted mb-4 mt-1">
            <small>Ingrese su usuario y contraseña para continuar</small>
        </div>

        <div class="card-body p-0">

            @if (TempData["error"] != null)
            {
                <div class="alert alert-danger py-2" role="alert">
                    @Html.Raw(TempData["error"])
                </div>
            }

            @using (Html.BeginForm("ObtenerLogin", "Login", FormMethod.Post))
            {
                <div class="input-group mb-3">
                    <span class="input-group-text bg-white"><i class="bi bi-person text-muted"></i></span>
                    <input type="text" name="usuario" class="form-control" placeholder="Usuario" required />
                </div>

                <div class="input-group mb-4">
                    <span class="input-group-text bg-white"><i class="bi bi-lock text-muted"></i></span>
                    <input type="password" name="password" class="form-control" placeholder="Contraseña" required />
                </div>

                <button type="submit" class="btn btn-success"><i class="bi bi-check2"></i> Ingresar</button>
            }

            <div class="mt-4 text-muted" style="font-size: 0.9rem;">
                ¿No tiene usuario? <br />
                <a href="@Url.Action("Create", "Usuarios")" class="btn btn-secondary"><i class="bi bi-person-fill-add"></i> Registrarse</a>
            </div>

        </div>
    </div>
</div>

