@using Business;
@model Shared.DTOs.ContactosDTO

@{
    var tipos = (List<Shared.DTOs.ContactoMediosDTO>)ViewBag.TiposContacto;
}
<div class="container d-flex justify-content-center px-4">
    <div class="card media-card">

        <div class="header-bg p-4 text-center">
            <img src="~/Img/contactos/@(Model.ContactoId).@(Model.ExtensionImagen)"
                 class="rounded-circle shadow-sm mb-3"
                 style="width: 70px; height: 70px; object-fit: cover; border: 3px solid #fff;"
                 onerror="this.src='https://cdn-icons-png.flaticon.com/512/149/149071.png';" />
            <h4 class="mb-0 fw-bold text-dark">@Model.Nombre @Model.ApellidoPaterno</h4>
        </div>

        <div class="card-body p-4">

            @if (TempData["error"] != null)
            {
                <div class="alert alert-danger py-2 shadow-sm" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @Html.Raw(TempData["error"])
                </div>
            }

            <h6 class="fw-bold text-uppercase text-secondary small mb-3">
                <i class="bi bi-plus-circle me-1"></i> Agregar nuevo medio de contacto
            </h6>

            <form action="/Contactos/AgregarMedio" method="post" class="mb-4">
                <input type="hidden" name="ContactoId" value="@Model.ContactoId" />

                <div class="row g-2 align-items-center">
                    <div class="col-md-4">
                        <select name="TipoContactoId" class="form-select" required>
                            <option value="" disabled selected>Seleccione el tipo...</option>
                            @foreach (var tipo in tipos)
                            {
                                <option value="@tipo.TipoContactoId">@tipo.Descripcion</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <input type="text" name="Valor" class="form-control" placeholder="55 1234 5678 o enlace" required />
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100 shadow-sm">
                            <i class="bi bi-plus-lg"></i>
                        </button>
                    </div>
                </div>
            </form>

            <hr class="text-muted opacity-25 mb-4">

            <h6 class="fw-bold text-uppercase text-secondary small mb-3">
                <i class="bi bi-list-check me-1"></i> Medios registrados
            </h6>

            @if (Model.ContactoMedios == null || Model.ContactoMedios.Length == 0)
            {
                <div class="text-center py-4 bg-light rounded-3 border border-light">
                    <i class="bi bi-inbox text-muted" style="font-size: 2rem;"></i>
                    <p class="text-muted mt-2 mb-0 small">No hay medios de contacto registrados aún.</p>
                </div>
            }
            else
            {
                <ul class="list-group shadow-sm">
                    @foreach (var medio in Model.ContactoMedios)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center p-3 border-light">
                            <div>
                                <span class="text-muted" style="font-size: 1.0rem;">
                                    @if (medio.TipoContactoId == 1)
                                    {<i class="bi bi-telephone" style="color: black"></i>}
                                    @if (medio.TipoContactoId == 2)
                                    {<i class="bi bi-linkedin" style="color: #0e76a8"></i>}
                                    @if (medio.TipoContactoId == 3)
                                    {<i class="bi bi-facebook" style="color: #3b5998"></i>}
                                    @if (medio.TipoContactoId == 4)
                                    {<i class="bi bi-instagram" style="color: hotpink"></i>}

                                </span>
                                <span class="fw-medium text-break">@medio.Valor</span>
                            </div>
                            <a href="/Contactos/EliminarMedio?contactoMedioId=@medio.ContactoMedioId&contactoId=@Model.ContactoId"
                               class="btn btn-outline-danger btn-sm"
                               onclick="return confirm('¿Está seguro de eliminar @medio.Descripcion?')">
                                <i class="bi bi-trash"></i>
                            </a>
                        </li>
                    }
                </ul>
            }

            <div class="text-center mt-5">
                <a href="/Contactos/Index" class="btn btn-success px-5 shadow-sm fw-semibold">
                    <i class="bi bi-check-circle me-2"></i> Finalizar y volver al Directorio
                </a>
            </div>

        </div>
    </div>
</div>