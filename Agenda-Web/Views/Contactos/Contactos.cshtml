@model List<Shared.DTOs.ContactoDTO>
@{
    ViewBag.Title = "Contactos";
}

<div class="container pb-5">
    <div class="col-md-3 col-lg-3">
        <h3 class="fw-bold text-dark m-0">Directorio</h3>
        <h6 class="fw-bold text-dark m-0">Tienes @Model.Count contactos</h6>
    </div>


    <div class="col-md-6 col-lg-6">
        @using (Html.BeginForm("Buscar", "Contactos", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <span class="input-group shadow-sm border-end-0">
                <i class="bi bi-search text-muted"></i>
            </span>

            <input type="text" name="busqueda" class="form-control border-start-0" placeholder="Buscar contacto por nombre o email..." />

            <button type="submit" class="btn btn-secondary px-4">Buscar</button>
        }

        <div class="col-md-3 col-lg-3 text-md-end">
            <a href="@Url.Action()" class="btn btn-success shadow-sm fw-semibold w-75">
                <i class="bi bi-plus-lg me-1"></i> Agregar Contacto
            </a>
        </div>

        @if (TempData["error"] != null)
        {
            <div class="alert alert-danger shadow-sm py-2" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @Html.Raw(TempData["error"])
            </div>
        }

        @if (Model == null || Model.Count == 0)
        {
            <div class="text-center py-5 bg-white rounded-3 shadow-sm mt-3">
                <i class="bi bi-search text-muted" style="font-size: 4rem;"></i>
                <h4 class="mt-3 text-muted">No se encontraron contactos</h4>
                <p class="text-secondary">Intenta con otro término de búsqueda o agrega un nuevo contacto a la agenda.</p>
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var contacto in Model)
                {
                    bool esCumpleanos = contacto.FechaNacimiento.HasValue &&
                                        contacto.FechaNacimiento.Value.Day == DateTime.Today.Day &&
                                        contacto.FechaNacimiento.Value.Month == DateTime.Today.Month;

                    <div class="col-12">
                        <div class="card contacto-card w-100">
                            <div class="card-body p-4 row align-items-center m-0">

                                <div class="col-md-4 col-lg-4 d-flex align-items-center mb-3 mb-md-0 ps-0">
                                    <img src="~/Img/contactos/@(contacto.ContactoId).@(contacto.ExtensionImagen)"
                                         class="rounded-circle avatar-img me-3 shadow-sm flex-shrink-0"
                                         alt="Foto" />
                                    <div class="overflow-hidden">
                                        <h5 class="mb-1 fw-bold text-dark text-truncate" title="@contacto.Nombre @contacto.ApellidoPaterno">
                                            @contacto.Nombre @contacto.ApellidoPaterno
                                        </h5>
                                        <div class="text-muted small text-truncate" title="@contacto.CorreoElectronico">
                                            <i class="bi bi-envelope-at me-1"></i>@contacto.CorreoElectronico
                                        </div>

                                        @if (esCumpleanos)
                                        {
                                            <div class="mt-1 text-success fw-bold" style="font-size: 0.85rem;">
                                                <i class="bi bi-cake2-fill me-1"></i>¡Hoy es su cumpleaños!
                                            </div>
                                        }
                                    </div>
                                </div>

                                <div class="col-md-6 col-lg-6 divisor-vertical ps-md-4 mb-3 mb-md-0">
                                    <h6 class="text-secondary small fw-bold text-uppercase mb-2 d-none d-md-block">Información de Contacto</h6>
                                    @if (contacto.ContactoMedios != null && contacto.ContactoMedios.Count > 0)
                                    {
                                        <div class="row g-2">
                                            @foreach (var medio in contacto.ContactoMedios)
                                            {
                                                <div class="col-sm-6">
                                                    <div class="p-2 bg-light rounded border border-light h-100">
                                                        <span class="text-muted d-block" style="font-size: 0.75rem;">
                                                            @if (medio.TipoContactoId == 1)
                                                            {<i class="bi bi-telephone" style="color: black"></i>}
                                                            @if (medio.TipoContactoId == 2)
                                                            {<i class="bi bi-linkedin" style="color: #0e76a8"></i>}
                                                            @if (medio.TipoContactoId == 3)
                                                            {<i class="bi bi-facebook" style="color: #3b5998"></i>}
                                                            @if (medio.TipoContactoId == 4)
                                                            {<i class="bi bi-instagram" style="color: hotpink"></i>}
                                                            @medio.Descripcion
                                                        </span>
                                                        <strong class="small text-break">@medio.Valor</strong>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <p class="text-muted small fst-italic mb-0 py-1">Sin medios registrados.</p>
                                    }
                                </div>

                                <div class="col-md-2 col-lg-2 d-flex flex-row flex-md-column gap-2 border-top border-md-0 pt-3 pt-md-0 pe-0">
                                    <a href="@Url.Action("Edit", "Contactos", new { contactoId = contacto.ContactoId})" class="btn btn-outline-primary btn-sm w-100">
                                        <i class="bi bi-pencil-square me-1"></i> Editar
                                    </a>
                                    <a href="@Url.Action("Delete", "Contactos", new { contactoId = contacto.ContactoId})" class="btn btn-outline-danger btn-sm w-100" onclick="return confirm('¿Eliminar definitivamente a @contacto.Nombre?')">
                                        <i class="bi bi-trash me-1"></i> Eliminar
                                    </a>
                                </div>

                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>


